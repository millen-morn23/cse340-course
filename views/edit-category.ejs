<%- include('partials/header') %>

<main class="container">

  <h1><%= title %></h1>

  <form
    action="/edit-category/<%= category.category_id %>"
    method="POST"
  >

    <div class="form-group">

      <label for="name">
        Category Name
      </label>

      <input
        type="text"
        id="name"
        name="name"
        required
        maxlength="100"
        value="<%= category.name %>"
      />

    </div>

    <button type="submit">
      Update Category
    </button>

  </form>

</main>

<%- include('partials/footer') %>