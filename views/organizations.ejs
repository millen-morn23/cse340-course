<%- include('partials/header', { title: 'Organizations' }) %>

<h1>Organizations</h1>

<div class="org-container">

  <% organizations.forEach(org => { %>

    <div class="org-card">

      <img
        src="<%= org.image %>"
        alt="<%= org.name %>"
        width="300"
      >

      <h2>
        <a href="/organization/<%= org.id %>">
          <%= org.name %>
        </a>
      </h2>

      <p>
        <%= org.description %>
      </p>

      <p>
        Email:
        <%= org.contact_email %>
      </p>

    </div>

  <% }) %>

</div>

<% if (
  user &&
  user.role_name === 'admin'
) { %>

  <p>
    <a href="/new-organization">
      Add a new organization
    </a>
  </p>

<% } %>

<%- include('partials/footer') %>