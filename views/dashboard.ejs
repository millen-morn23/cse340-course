<%- include('partials/header') %>

<main>

  <h1>
    Dashboard
  </h1>

  <p>
    Welcome,
    <strong><%= name %></strong>
  </p>

  <p>
    Your email:
    <strong><%= email %></strong>
  </p>

  <% if (
    user &&
    user.role_name === 'admin'
  ) { %>

    <p>

      <a href="/users">
        View Registered Users
      </a>

    </p>

  <% } %>

  <hr>

  <h2>
    My Volunteer Projects
  </h2>

  <% if (
    volunteerProjects.length > 0
  ) { %>

    <ul>

      <% volunteerProjects.forEach(project => { %>

        <li>

          <strong>

            <a
              href="/project/<%= project.project_id %>"
            >
              <%= project.title %>
            </a>

          </strong>

          <br>

          <%= project.location %>

          <br>

          <form
            action="/remove-volunteer/<%= project.project_id %>"
            method="POST"
          >

            <button type="submit">
              Remove Volunteer Status
            </button>

          </form>

          <br>

        </li>

      <% }) %>

    </ul>

  <% } else { %>

    <p>
      You have not volunteered for any projects yet.
    </p>

  <% } %>

</main>

<%- include('partials/footer') %>