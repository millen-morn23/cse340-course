<%- include('partials/header') %>

<h1><%= organizationDetails.name %></h1>

<div class="card">

  <img
    src="<%= organizationDetails.image %>"
    alt="<%= organizationDetails.name %>"
    width="300"
  >

  <p>
    <strong>Description:</strong>
    <%= organizationDetails.description %>
  </p>

  <p>
    <strong>Contact Email:</strong>
    <%= organizationDetails.contact_email %>
  </p>

</div>

<h2>Service Projects</h2>

<% if (projects.length > 0) { %>

  <ul>

    <% projects.forEach(project => { %>

      <li>

        <a href="/project/<%= project.project_id %>">
          <%= project.title %>
        </a>

        - <%= project.location %>

      </li>

    <% }) %>

  </ul>

<% } else { %>

  <p>No projects found for this organization.</p>

<% } %>

<%- include('partials/footer') %>